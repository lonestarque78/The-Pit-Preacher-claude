# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# Project URL — found in Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key — safe to expose in the browser (row-level security enforced)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — server-side ONLY, has full DB access, never expose to client
SUPABASE_SERVICE_ROLE_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Stripe
# Publishable key — safe to expose in the browser (starts with pk_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_

# Secret key — server-side ONLY (starts with sk_)
STRIPE_SECRET_KEY=sk_test_

# Webhook signing secret — from Stripe dashboard → Webhooks → your endpoint (starts with whsec_)
STRIPE_WEBHOOK_SECRET=whsec_

# ─────────────────────────────────────────────────────────────────────────────
# Stripe Subscription Price IDs (monthly)
# Create these in Stripe dashboard → Products → your plan → Add price
NEXT_PUBLIC_STRIPE_BASIC_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_BACKYARD_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_PITMASTER_PRICE_ID=price_

# Stripe Subscription Price IDs (annual)
NEXT_PUBLIC_STRIPE_BASIC_ANNUAL_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_BACKYARD_ANNUAL_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_PITMASTER_ANNUAL_PRICE_ID=price_

# Legacy/server-side price ID aliases (used in some API routes)
STRIPE_BASIC_PRICE_ID=price_
STRIPE_PITMASTER_PRICE_ID=price_

# ─────────────────────────────────────────────────────────────────────────────
# Stripe Photo Pack Add-on Price IDs
NEXT_PUBLIC_STRIPE_PHOTO_1_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_PHOTO_2_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_PHOTO_3_PRICE_ID=price_
NEXT_PUBLIC_STRIPE_PHOTO_4_PRICE_ID=price_

# ─────────────────────────────────────────────────────────────────────────────
# App URLs
# Full public URL of the app (used for redirects, Stripe success/cancel URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Anthropic / Claude AI
# API key from https://console.anthropic.com (starts with sk-ant-)
ANTHROPIC_API_KEY=sk-ant-

# Model ID to use — see https://docs.anthropic.com/en/docs/about-claude/models
ANTHROPIC_MODEL=claude-sonnet-4-20250514
